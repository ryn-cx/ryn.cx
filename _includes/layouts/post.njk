---
# TODO: Validate
layout: layouts/base.njk
---
<h1 class="text-5xl font-bold text-center mb-4">{{ title }}</h1>

<div class="text-center mb-4">
	<time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate("MMMM dd, yyyy") }}</time>
</div>

<div class="prose prose-lg mx-auto">
	{{ content | safe }}
</div>

{%- if collections.posts %}
	{%- set previousPost = collections.posts | getPreviousCollectionItem %}
	{%- set nextPost = collections.posts | getNextCollectionItem %}
	{%- if nextPost or previousPost %}
		<ul class="links-nextprev">
			{%- if previousPost %}
				<li class="links-nextprev-prev">← Previous<br>
					<a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a>
				</li>
			{% endif %}
			{%- if nextPost %}
				<li class="links-nextprev-next">Next →<br>
					<a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
				</li>
			{% endif %}
		</ul>
	{%- endif %}
{%- endif %}